FROM eclipse-temurin:8-jre

ARG JAR_FILE=output/laike-apis-0.0.1-SNAPSHOT.jar

ENV TZ=Asia/Shanghai \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    JAVA_OPTS="-Xms1g -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -Dfile.encoding=UTF-8"

WORKDIR /opt/laike/apis

RUN mkdir -p /opt/laike/apis/app /opt/laike/apis/config /opt/laike/apis/logs /opt/laike/apis/upload /opt/laike/apis/xxl-logs

COPY ${JAR_FILE} /opt/laike/apis/app/laike-apis.jar

EXPOSE 21898

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar /opt/laike/apis/app/laike-apis.jar --spring.config.additional-location=file:/opt/laike/apis/config/bootstrap.yml --logging.file.path=/opt/laike/apis/logs --uploadFile.path=/opt/laike/apis/upload/ --xxl.job.executor.logpath=/opt/laike/apis/xxl-logs"]
