<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 日志格式 -->
    <property name="LOG_PATTERN" value="%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n" />

    <!-- 默认日志路径（用于 local / inter 等非生产环境） -->
    <property name="DEFAULT_LOG_PATH" value="./logs" />

    <!-- =============== 环境专属路径 =============== -->

    <!-- 本地开发 -->
    <springProfile name="local">
        <property name="LOG_PATH" value="${DEFAULT_LOG_PATH}" />
    </springProfile>

    <!-- 集成测试 -->
    <springProfile name="inter">
        <property name="LOG_PATH" value="${DEFAULT_LOG_PATH}" />
    </springProfile>

    <!-- 生产环境 -->
    <springProfile name="prod">
        <property name="LOG_PATH" value="./logs" />
        <!-- 或指定绝对路径：<property name="LOG_PATH" value="/data/laike/logs" /> -->
    </springProfile>

    <!-- 演示环境 -->
    <springProfile name="demo">
        <property name="LOG_PATH" value="/usr/local/tomcat/webapps/apps/logs" />
    </springProfile>

    <!-- 如果未激活任何 profile，默认用 local -->
    <if condition='!isDefined("LOG_PATH")'>
        <then>
            <property name="LOG_PATH" value="${DEFAULT_LOG_PATH}" />
        </then>
    </if>

    <!-- 文件路径定义 -->
    <property name="FILE_PATH" value="${LOG_PATH}/apis.%d{yyyy-MM-dd}.%i.log" />
    <property name="ERROR_FILE_PATH" value="${LOG_PATH}/apis-error.%d{yyyy-MM-dd}.%i.log" />

    <!-- =============== Appenders =============== -->

    <!-- 控制台 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 普通日志文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/apis.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${FILE_PATH}</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>10</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 错误日志文件 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <file>${LOG_PATH}/apis-error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${ERROR_FILE_PATH}</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- =============== Loggers =============== -->

    <!-- 显式配置 springdoc 包及其子包下所有 logger 的级别为 WARN -->
    <!-- 这会覆盖 ROOT 的 INFO 级别，并且 additivity=false 避免日志传递给 ROOT -->
    <logger name="org.springdoc" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <!-- ERROR_FILE 通常不需要，因为这里是 WARN -->
    </logger>

    <!-- =============== Root Logger =============== -->

    <!-- 所有环境都启用 console + file -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
        <appender-ref ref="ERROR_FILE" />
    </root>

    <!-- 本地开发可以设为 DEBUG（可选） -->
    <springProfile name="local">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
    </springProfile>

    <!-- 演示环境降低日志级别 -->
    <springProfile name="demo">
        <root level="WARN">
            <appender-ref ref="CONSOLE" />
            <appender-ref ref="FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
    </springProfile>

</configuration>