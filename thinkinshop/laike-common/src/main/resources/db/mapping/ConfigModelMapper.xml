<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.laiketui.common.mapper.ConfigModelMapper" >

    <select id="selectByStoreIds" resultType="com.laiketui.domain.config.ConfigModel">
        SELECT * FROM lkt_config
        WHERE store_id IN
        <foreach collection="storeIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>