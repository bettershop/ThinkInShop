<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.laiketui.common.mapper.FileDeliveryModelMapper" >

  <sql id="selectDynamicSQL">
    <if test="mchId != null">and `mch_id` = #{mchId}</if>
    <if test="name != null">and `name` like concat('%',#{name},'%')</if>
    <if test="status != null">and `status` = #{status}</if>
    <if test="startDate != null and startDate != ''">and add_date <![CDATA[  >=  ]]> #{startDate}</if>
    <if test="endDate != null and endDate != ''">and add_date <![CDATA[  <=  ]]> #{endDate}</if>
    <if test="type != null"> and `type` = #{type}</if>
  </sql>

  <select id="selectDynamic" parameterType="Map" resultType="Map">
    select id,name,title,upload_path,status,`text`,is_del,mch_id,DATE_FORMAT(add_date, '%Y-%m-%d %H:%i:%s') as add_date,update_date,type,order_num from lkt_file_delivery
    <where>
      <trim prefixOverrides="and">
        <include refid="selectDynamicSQL"/>
      </trim>
    </where>
    <trim prefix="order by" suffixOverrides=",">
      <if test="add_date_sort!=null and add_date_sort!=''">add_date ${add_date_sort},</if>
    </trim>
    <if test="pageStart != null and pageEnd != ''">limit #{pageStart},#{pageEnd}</if>
  </select>
  <select id="countDynamic" parameterType="Map" resultType="int">
    select count(1)
    from lkt_file_delivery
    <where>
      <trim prefixOverrides="and">
        <include refid="selectDynamicSQL"/>
      </trim>
    </where>
  </select>

</mapper>