<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.laiketui.common.mapper.SupplierAccountLogModelMapper" >

    <select id="getAccountLog" parameterType="Map" resultType="Map">
        select * from lkt_supplier_account_log
        <where>
            <trim prefixOverrides="and">
                <include refid="getWithdrawLeftUserBankSQL"/>
            </trim>
        </where>
        <trim prefix="order by" suffixOverrides=",">
            <if test="add_date_sort!=null and add_date_sort!=''">add_time ${add_date_sort},</if>
        </trim>
        <if test="pageStart!=null and pageEnd!=null">limit #{pageStart},#{pageEnd}</if>
    </select>

    <select id="countAccountLog" parameterType="Map" resultType="int">
        select count(*) from lkt_supplier_account_log
        <where>
            <trim prefixOverrides="and">
                <include refid="getWithdrawLeftUserBankSQL"/>
            </trim>
        </where>
    </select>

    <select id="countAccountLogMoney" parameterType="Map" resultType="BigDecimal">
        select IFNULL(sum(amount),0) amount from lkt_supplier_account_log
        <where>
            <trim prefixOverrides="and">
                <include refid="getWithdrawLeftUserBankSQL"/>
            </trim>
        </where>
    </select>

    <sql id="getWithdrawLeftUserBankSQL">
        and store_id = #{storeId}
        <if test="id != null">AND id = #{id}</if>
        <if test="supplierId != null">AND supplier_id = #{supplierId}</if>
        <if test="status != null">AND status = #{status}</if>
        <if test="type != null">AND type = #{type}</if>
        <if test="remake != null">AND remake = #{remake}</if>
        <if test="startTime != null">AND add_time <![CDATA[ >= ]]> #{startTime}</if>
        <if test="endTime != null">AND add_time <![CDATA[ <= ]]> #{endTime}</if>
    </sql>

</mapper>