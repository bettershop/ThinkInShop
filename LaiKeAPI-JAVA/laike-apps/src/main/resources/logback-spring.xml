<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 格式化输出：%date表示日期，%thread表示线程名，%-5level：级别从左显示5个字符宽度 %msg：日志消息，%n是换行符-->
    <property name="LOG_PATTERN" value="%date{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n" />

    <!-- 本地和生产环境 -->
    <springProfile name="prod">
        <property name="LOG_PATH" value="./../webapps/apps/logs/"/>
        <property name="FILE_PATH" value="${LOG_PATH}/apps.%d{yyyy-MM-dd}.%i.log"/>
        <property name="ERROR_FILE_PATH" value="${LOG_PATH}/apps-error.%d{yyyy-MM-dd}.%i.log"/>
    </springProfile>

    <springProfile name="inter">
        <property name="LOG_PATH" value="./../webapps/apps/logs/"/>
        <property name="FILE_PATH" value="${LOG_PATH}/apps.%d{yyyy-MM-dd}.%i.log"/>
        <property name="ERROR_FILE_PATH" value="${LOG_PATH}/apps-error.%d{yyyy-MM-dd}.%i.log"/>
    </springProfile>

    <springProfile name="local">
        <property name="LOG_PATH" value="./../webapps/apps/logs/"/>
        <property name="FILE_PATH" value="${LOG_PATH}/apps.%d{yyyy-MM-dd}.%i.log"/>
        <property name="ERROR_FILE_PATH" value="${LOG_PATH}/apps-error.%d{yyyy-MM-dd}.%i.log"/>
    </springProfile>

    <!-- 对外演示环境 -->
    <springProfile name="demo">
        <property name="LOG_PATH" value="/usr/local/tomcat/webapps/apps/logs"/>
        <property name="FILE_PATH" value="${LOG_PATH}/apps.%d{yyyy-MM-dd}.%i.log"/>
        <property name="ERROR_FILE_PATH" value="${LOG_PATH}/apps-error.%d{yyyy-MM-dd}.%i.log"/>
    </springProfile>

    <!-- 控制台输出日志 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 按照上面配置的LOG_PATTERN来打印日志 -->
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!--每天生成一个日志文件，保存10天的日志文件。rollingFile是用来切分文件的 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${FILE_PATH}</fileNamePattern>
            <maxHistory>10</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 仅 ERROR 日志文件 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${ERROR_FILE_PATH}</fileNamePattern>
            <maxHistory>30</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy
                    class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 根日志设置 -->
    <springProfile name="demo">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>
    <springProfile name="inter">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>
    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>
</configuration>