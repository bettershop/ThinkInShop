<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.laiketui.common.mapper.InvoiceHeaderModelMapper" >

    <sql id="getDynamicSQL">
        <where>
            <trim prefixOverrides="and">
                AND a.store_id = #{storeId}
                AND a.recovery = 0
                <if test="id != null">AND a.id = #{id}</if>
                <if test="userId != null">AND a.user_id = #{userId}</if>
                <if test="type != null">AND a.type = #{type}</if>
                <if test="companyName != null">AND a.company_name like CONCAT('%',#{companyName},'%')</if>
                <if test="isDefault != null">AND a.is_default = #{isDefault}</if>
            </trim>
        </where>
    </sql>

    <select id="getList" parameterType="Map" resultType="Map">
        SELECT * FROM lkt_invoice_header a
        <include refid="getDynamicSQL"/>
        <trim prefix=" ORDER BY " suffixOverrides=",">
            <if test="addTimeSort != null">add_time ${addTimeSort},</if>
        </trim>
        <if test="page != null and pageSize!=null">LIMIT #{page},#{pageSize}</if>
    </select>

    <select id="countList" parameterType="Map" resultType="Integer">
        SELECT count(1) FROM lkt_invoice_header a
        <include refid="getDynamicSQL"/>
    </select>

</mapper>